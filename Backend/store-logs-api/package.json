{
    "name": "emp-service",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "prebuild": "rimraf dist",
        "prestart:prod": "npm i",
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "pm2 start dist/main.js -i max",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "compodoc": "npx compodoc -p tsconfig.json -s -w",
        "migrate-mongo:up": "npx migrate-mongo up -f ./mongo-migrations/migrate-mongo-config.js",
        "migrate-mongo:down": "npx migrate-mongo down -f ./mongo-migrations/migrate-mongo-config.js",
        "migrate-mysql:up": "npx sequelize db:migrate",
        "migrate-mysql:down": "npx sequelize db:migrate:undo"
    },
    "dependencies": {
        "@hapi/joi": "^17.1.1",
        "@nestjs/common": "^11.1.17",
        "@nestjs/core": "^9.0.7",
        "@nestjs/platform-express": "^11.1.17",
        "async": "^3.2.6",
        "aws-sdk": "^2.1693.0",
        "axios": "^1.13.6",
        "basic-ftp": "^5.2.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "compression": "^1.8.1",
        "dropbox": "^10.34.0",
        "express-basic-auth": "^1.2.1",
        "fluent-ffmpeg": "2.1.2",
        "form-data": "^4.0.5",
        "googleapis": "^50.0.0",
        "helmet": "^3.22.0",
        "install": "^0.13.0",
        "migrate-mongo": "7.2.1",
        "moment-timezone": "^0.5.48",
        "mongoose": "^9.3.2",
        "mysql2": "^3.20.0",
        "nest-event": "^1.0.8",
        "nest-router": "^1.0.9",
        "nestjs-redis": "^1.2.8",
        "npm": "^11.12.0",
        "one-drive-api-pools": "^1.0.4",
        "promise-ftp": "^1.3.5",
        "query-string": "^6.13.0",
        "reflect-metadata": "^0.1.13",
        "rimraf": "^3.0.2",
        "rxjs": "^6.5.4",
        "sequelize": "^6.37.8",
        "sequelize-cli": "5.5.1",
        "sequelize-typescript": "^2.1.6",
        "sockjs-client": "^1.6.1",
        "ssh2-sftp-client": "^9.1.0",
        "swagger-ui-express": "^4.6.3",
        "underscore": "^1.13.8",
        "webdav": "^5.9.0",
        "winston": "^3.3.3",
        "winston-daily-rotate-file": "^4.5.5",
        "zoho-wd-pools": "1.0.0"
    },
    "devDependencies": {
        "@compodoc/compodoc": "^1.2.1",
        "@nestjs/cli": "^11.0.16",
        "@nestjs/config": "^0.4.0",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/mongoose": "^11.0.4",
        "@nestjs/schematics": "^7.0.0",
        "@nestjs/swagger": "^4.5.1",
        "@nestjs/testing": "^7.0.0",
        "@types/async": "^3.2.1",
        "@types/express": "^4.17.3",
        "@types/hapi__joi": "^16.0.12",
        "@types/jest": "25.1.4",
        "@types/moment-timezone": "^0.5.13",
        "@types/mongoose": "^5.7.8",
        "@types/multer": "^1.4.3",
        "@types/node": "^13.9.1",
        "@types/sequelize": "^4.28.8",
        "@types/ssh2-sftp-client": "^9.0.1",
        "@types/supertest": "^2.0.8",
        "@types/underscore": "^1.9.4",
        "@typescript-eslint/eslint-plugin": "^2.23.0",
        "@typescript-eslint/parser": "^2.23.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^6.10.0",
        "eslint-plugin-import": "^2.20.1",
        "jest": "^30.3.0",
        "prettier": "^1.19.1",
        "supertest": "^7.2.2",
        "ts-jest": "25.5.1",
        "ts-loader": "^6.2.1",
        "ts-node": "^8.6.2",
        "tsconfig-paths": "^3.9.0",
        "typescript": "^3.7.4"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".spec.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
